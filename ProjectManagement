<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Project Manager</title>
<style>
body{margin:0;background:#111;color:#eee;font-family:Arial,sans-serif} .wrap{padding:20px} h1{margin:0 0 16px;font-size:28px}.toolbar{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap}.btn,input,select{background:#1e1e1e;color:#eee;border:1px solid #333;border-radius:8px;padding:8px}.group{margin:20px 0}.group h2{font-size:18px;background:#222;padding:8px 10px;border-radius:8px;display:inline-block}.tableWrap{overflow:auto}.tbl{width:100%;border-collapse:collapse;min-width:1200px}.tbl th,.tbl td{border-bottom:1px solid #2a2a2a;padding:8px;text-align:left;font-size:14px}.tbl th{color:#aaa;position:sticky;top:0;background:#111}.tbl tr:hover{background:#171717}.tag{padding:4px 8px;border-radius:999px;background:#2d4f7c}.done{background:#235c3b}.muted{color:#999}</style>
</head>
<body><div class='wrap'>
<h1>Management</h1>
<div class='toolbar'>
<button class='btn' onclick='addRow()'>+ 新規追加</button>
<button class='btn' onclick='resetData()'>初期化</button>
<input id='search' placeholder='検索...' oninput='render()'>
</div>
<div id='app'></div>
</div>
<script>
const KEY='wp_notion_projects_v1';
const statuses=['01 In progress','02 Not started','03 Done'];
const defaults=[{no:'April',priority:2,company:'スターワークス',job:'.Net',applied:'2026-04-19',manager:'採用担当',salary:550,result:'書類通過',response:25,next:'2026-04-21',progress:'書類提出予定',memo:'注文多め',status:'01 In progress'}];
function load(){return JSON.parse(localStorage.getItem(KEY)||'null')||defaults}
function save(){localStorage.setItem(KEY,JSON.stringify(data))}
let data=load();
function addRow(){data.unshift({no:'',priority:0,company:'',job:'',applied:'',manager:'',salary:0,result:'',response:0,next:'',progress:'',memo:'',status:'02 Not started'});save();render();}
function resetData(){if(confirm('保存データを削除しますか？')){localStorage.removeItem(KEY);data=load();render();}}
function update(i,k,v){data[i][k]=['priority','salary','response'].includes(k)?Number(v||0):v;save();render();}
function removeRow(i){data.splice(i,1);save();render();}
function row(r,i){return `<tr><td><input value='${r.no}' onchange="update(${i},'no',this.value)"></td><td><input type='number' value='${r.priority}' onchange="update(${i},'priority',this.value)" style='width:70px'></td><td><input value='${r.company}' onchange="update(${i},'company',this.value)"></td><td><input value='${r.job}' onchange="update(${i},'job',this.value)"></td><td><input type='date' value='${r.applied}' onchange="update(${i},'applied',this.value)"></td><td><input value='${r.manager}' onchange="update(${i},'manager',this.value)"></td><td><input type='number' value='${r.salary}' onchange="update(${i},'salary',this.value)" style='width:80px'></td><td><input value='${r.result}' onchange="update(${i},'result',this.value)"></td><td><input type='number' value='${r.response}' onchange="update(${i},'response',this.value)" style='width:70px'></td><td><input type='date' value='${r.next}' onchange="update(${i},'next',this.value)"></td><td><input value='${r.progress}' onchange="update(${i},'progress',this.value)"></td><td><input value='${r.memo}' onchange="update(${i},'memo',this.value)"></td><td><select onchange="update(${i},'status',this.value)">${statuses.map(s=>`<option ${s===r.status?'selected':''}>${s}</option>`).join('')}</select></td><td><button class='btn' onclick='removeRow(${i})'>削除</button></td></tr>`}
function render(){const q=document.getElementById('search').value.toLowerCase();let html='';statuses.forEach(st=>{const rows=data.map((r,i)=>({...r,_i:i})).filter(r=>r.status===st).filter(r=>JSON.stringify(r).toLowerCase().includes(q));html+=`<div class='group'><h2>${st}</h2><div class='tableWrap'><table class='tbl'><thead><tr><th>no</th><th>priority</th><th>company</th><th>job</th><th>applied</th><th>manager</th><th>salary</th><th>result</th><th>resp%</th><th>next</th><th>progress</th><th>memo</th><th>Status</th><th></th></tr></thead><tbody>${rows.length?rows.map(r=>row(r,r._i)).join(''):`<tr><td colspan='14' class='muted'>データなし</td></tr>`}</tbody></table></div></div>`});document.getElementById('app').innerHTML=html;}
render();
function render(){const q=document.getElementById('search').value.toLowerCase();let html="<div style='max-width:720px'>";statuses.forEach(st=>{const rows=data.map((r,i)=>({...r,_i:i})).filter(r=>r.status===st).filter(r=>JSON.stringify(r).toLowerCase().includes(q));html+=`<div class='group'><h2>${st}</h2>${rows.length?'':'<div class="muted">データなし</div>'}`;rows.forEach(r=>{html+=`<div style='background:#1a1a1a;border:1px solid #2a2a2a;border-radius:12px;padding:12px;margin:10px 0;'>
<div style='display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap'><div><b>${r.company||'-'}</b></div><div>Priority ${r.priority}</div><div><select onchange="update(${r._i},'status',this.value)">${statuses.map(s=>`<option ${s===r.status?'selected':''}>${s}</option>`).join('')}</select></div></div>
<div style='display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-top:8px'><div>職種: <input value='${r.job}' onchange="update(${r._i},'job',this.value)"></div><div>給与: <input type='number' style='width:90px' value='${r.salary}' onchange="update(${r._i},'salary',this.value)">万</div></div>
<div style='display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-top:8px'><div>応募: <input type='date' value='${r.applied}' onchange="update(${r._i},'applied',this.value)"></div><div>次回: <input type='date' value='${r.next}' onchange="update(${r._i},'next',this.value)"></div></div>
<div style='margin-top:8px'>進捗:<br><textarea style='width:100%;min-height:52px;background:#111;color:#eee;border:1px solid #333;border-radius:8px' onchange="update(${r._i},'progress',this.value)">${r.progress||''}</textarea></div>
<div style='margin-top:8px'>メモ:<br><textarea style='width:100%;min-height:52px;background:#111;color:#eee;border:1px solid #333;border-radius:8px' onchange="update(${r._i},'memo',this.value)">${r.memo||''}</textarea></div>
<div style='display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-top:8px'><div>担当: <input value='${r.manager}' onchange="update(${r._i},'manager',this.value)"></div><button class='btn' onclick='removeRow(${r._i})'>削除</button></div>
</div>`});html+='</div>'});html+='</div>';document.getElementById('app').innerHTML=html;} render();
</script></body></html>
